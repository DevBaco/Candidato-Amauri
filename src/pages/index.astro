---
import Layout from '../layouts/Layout.astro';

const whatsappHref =
  'https://wa.me/5531998533595?text=Ol%C3%A1%2C%20quero%20apoiar%20a%20campanha%20do%20Amauri%20Dami%C3%A3o.';

const navItems = [
  { label: 'História', href: '#historia' },
  { label: 'Propostas', href: '#bandeiras' },
  { label: 'Apoie', href: '#apoie' },
];

const timeline = [
  {
    label: 'Origem',
    text: 'Natural do distrito de Jiboia, em São Francisco, cresceu perto da realidade das famílias rurais do Norte de Minas.',
  },
  {
    label: 'Formação',
    text: 'Ex-aluno das Escolas Caio Martins, em Esmeraldas. Atribui sua trajetória à disciplina, ao respeito e à educação que recebeu.',
  },
  {
    label: 'Compromisso',
    text: 'Não vem da política tradicional. Sua caminhada nasceu do trabalho e da convivência com as necessidades do povo.',
  },
];

const platform = [
  {
    title: 'Educação que transforma',
    text: 'Revitalizar escolas, ampliar o ensino técnico e abrir caminhos para os jovens do interior permanecerem em suas comunidades.',
  },
  {
    title: 'Emprego e renda',
    text: 'Atrair empresas, apoiar o comércio local, incentivar a agroindústria e qualificar a mão de obra da região. O maior programa social é o emprego.',
  },
  {
    title: 'Rio, turismo e cultura',
    text: 'Estruturar a rota turística do Rio São Francisco, valorizar a fé, a gastronomia, as praias fluviais e o Parque do Peruaçu.',
  },
  {
    title: 'Quem produz merece respeito',
    text: 'Defender a agricultura familiar com irrigação, estradas, energia, crédito rural e segurança hídrica.',
  },
];

const impactStats = [
  { value: '01', label: 'Educação como prioridade' },
  { value: '02', label: 'Ensino técnico e permanência no interior' },
  { value: '03', label: 'Frentes de trabalho para o Norte de Minas' },
];

const regionalPlan = [
  'Água, irrigação e segurança hídrica para quem produz',
  'Estradas vicinais, acesso a mercados e apoio ao pequeno produtor',
  'Turismo de natureza, fé, gastronomia e cultura no Rio São Francisco',
];

const audienceGroups = [
  {
    title: 'Educação',
    text: 'Ex-alunos, professores e famílias que acreditam na escola como virada de vida.',
    icon: 'book',
  },
  {
    title: 'Trabalho',
    text: 'Trabalhadores, comerciantes e jovens que querem oportunidade perto de casa.',
    icon: 'briefcase',
  },
  {
    title: 'Produção',
    text: 'Pequenos produtores, agricultores familiares e pecuaristas do Norte de Minas.',
    icon: 'sprout',
  },
  {
    title: 'Tradição',
    text: 'Comunidades rurais, romarias, cavalgadas e lideranças de fé.',
    icon: 'heart',
  },
];

const audienceIcons = {
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"/>',
  briefcase: '<path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"/><path d="M3 7h18v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 12h18"/><path d="M12 12v2"/>',
  sprout: '<path d="M7 20h10"/><path d="M12 20V10"/><path d="M12 10C9 10 7 8 7 5c3 0 5 2 5 5z"/><path d="M12 14c4 0 7-3 7-7-4 0-7 3-7 7z"/>',
  heart: '<path d="M20.8 4.6a5.4 5.4 0 0 0-7.6 0L12 5.8l-1.2-1.2a5.4 5.4 0 1 0-7.6 7.6L12 21l8.8-8.8a5.4 5.4 0 0 0 0-7.6z"/>',
};
---

<Layout>
  <header class="site-header">
    <div class="container header-inner">
      <a href="#inicio" class="brand" aria-label="Início — Amauri Damião">
        <img src="/assets/Logomarca_O_Democrata_35 - Alan Leal.png" alt="" width="1024" height="1024" />
        <strong>Amauri Damião</strong>
      </a>

      <nav class="nav" aria-label="Navegação principal">
        {navItems.map((item) => <a class="nav-link" href={item.href}>{item.label}</a>)}
      </nav>

      <div class="header-cta">
        <a class="btn btn-outline" href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">Instagram</a>
        <a class="btn btn-milho" href={whatsappHref} target="_blank" rel="noreferrer">Quero apoiar</a>
      </div>

      <button class="menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div class="mobile-menu" hidden>
      <div class="container">
        {navItems.map((item) => <a class="mobile-link" href={item.href}>{item.label}</a>)}
        <a class="btn btn-milho" style="margin-top:14px" href={whatsappHref} target="_blank" rel="noreferrer">Quero apoiar</a>
      </div>
    </div>
  </header>

  <main id="inicio">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>

      <div class="hero-topbar">
        <div class="container">
          <span class="hero-tagline">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 3 1 8l11 5 9-4.1V15h2V8L12 3ZM5 13.2V17c0 1.7 3.1 3 7 3s7-1.3 7-3v-3.8l-7 3.2-7-3.2Z" />
            </svg>
            Educação hoje, <b>futuro</b> amanhã.
          </span>
          <div class="hero-social">
            <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4a3.8 3.8 0 0 1-1.4-.9 3.8 3.8 0 0 1-.9-1.4c-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.1 0-3.5 0-4.7.1-.9 0-1.4.2-1.7.3-.4.2-.7.4-1 .7-.3.3-.5.6-.7 1-.1.3-.3.8-.3 1.7-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 .9.2 1.4.3 1.7.2.4.4.7.7 1 .3.3.6.5 1 .7.3.1.8.3 1.7.3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c.9 0 1.4-.2 1.7-.3.4-.2.7-.4 1-.7.3-.3.5-.6.7-1 .1-.3.3-.8.3-1.7.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-.9-.2-1.4-.3-1.7a2.7 2.7 0 0 0-.7-1 2.7 2.7 0 0 0-1-.7c-.3-.1-.8-.3-1.7-.3-1.2-.1-1.6-.1-4.7-.1Zm0 3.1a4.9 4.9 0 1 1 0 9.8 4.9 4.9 0 0 1 0-9.8Zm0 1.8a3.1 3.1 0 1 0 0 6.2 3.1 3.1 0 0 0 0-6.2Zm5.1-.3a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0Z" /></svg>
            </a>
            <a href={whatsappHref} target="_blank" rel="noreferrer" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" /></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="container hero-grid">
        <div class="hero-head reveal">
          <h1 class="hero-name">Amauri</h1>
          <p class="hero-surname">DAMIÃO</p>
          <p class="hero-role">Pré-candidato a Deputado Estadual</p>
        </div>

        <div class="hero-photo reveal">
          <div class="hero-blob" aria-hidden="true"></div>
          <div class="hero-figure">
            <img src="/assets/img_9490 - Alan Leal.png" alt="Amauri Damião" width="400" height="600" />
          </div>
        </div>

        <div class="hero-body reveal">
          <p class="hero-headline">Mais escolas, mais oportunidades, <em>um futuro melhor</em> para todos.</p>
          <p class="hero-sub">
            A educação transforma vidas e constrói uma sociedade mais justa. Esse é o caminho que vamos seguir,
            juntos, por Minas Gerais.
          </p>
          <a class="hero-wa" href={whatsappHref} target="_blank" rel="noreferrer">
            <span class="wa-circle">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" />
              </svg>
            </span>
            <span class="wa-text">
              <strong>FALE COM O AMAURI</strong>
              <span>Clique e mande uma mensagem</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- CITAÇÃO -->
    <section class="section band-quote">
      <div class="container reveal">
        <blockquote>A educação transformou minha vida, e pode transformar a vida de milhares de jovens mineiros.</blockquote>
        <cite>Amauri Damião</cite>
      </div>
    </section>

    <!-- HISTÓRIA -->
    <section id="historia" class="section">
      <div class="container story-grid">
        <figure class="photo-doc reveal" style="margin:0">
          <img
            src="/assets/ChatGPT Image 11 de jun. de 2026, 11_39_32 - Alan Leal.png"
            alt="Amauri Damião conversando com moradores da zona rural, embaixo de uma árvore"
            width="941"
            height="1672"
          />
          <figcaption>Norte de Minas · lado a lado com o povo da roça</figcaption>
        </figure>

        <div class="reveal">
          <p class="eyebrow">História de vida</p>
          <h2 class="title">Da Jiboia às Escolas Caio Martins: disciplina, trabalho e compromisso.</h2>
          <div class="timeline">
            {
              timeline.map((item) => (
                <article>
                  <span>{item.label}</span>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- MINAS QUE EDUCA -->
    <section class="section education-band">
      <div class="education-band-bg" aria-hidden="true">
        <img src="/assets/ia-turma-escola-mg.png" alt="" width="1680" height="960" />
      </div>
      <div class="container education-panel reveal">
        <p class="eyebrow on-dark">Minas que educa</p>
        <h2 class="title">A escola precisa abrir caminho para o trabalho, a cidadania e a permanência no interior.</h2>
        <p class="lead">
          A proposta é tratar educação como infraestrutura de futuro: salas bem cuidadas, ensino técnico, esporte,
          cultura e formação conectada com a vida real das famílias mineiras.
        </p>
        <div class="impact-strip" aria-label="Resumo das prioridades">
          {
            impactStats.map((item) => (
              <article>
                <strong>{item.value}</strong>
                <span>{item.label}</span>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- BANDEIRAS -->
    <section id="bandeiras" class="section">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Bandeiras principais</p>
          <h2 class="title">Quatro frentes pra fazer o Norte de Minas voltar a crescer.</h2>
        </div>
        <div class="regional-feature reveal">
          <img
            src="/assets/ia-rio-sao-francisco-norte-mg.png"
            alt="Rio São Francisco, agricultura irrigada e comunidades rurais do Norte de Minas"
            width="1680"
            height="960"
          />
          <div class="regional-copy">
            <p class="eyebrow">Desenvolvimento regional</p>
            <h3>O Rio São Francisco, o campo e as cidades pequenas precisam estar no centro das decisões.</h3>
            <ul>
              {regionalPlan.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
        <div class="platform">
          {
            platform.map((item, i) => (
              <article class="platform-item reveal">
                <div class="platform-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="platform-body">
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- QUEM REPRESENTA -->
    <section class="section section-osso-2 represent-section">
      <div class="represent-bg" aria-hidden="true">
        <img src="/assets/ia-comunidade-interior-mg.png" alt="" width="1680" height="960" />
      </div>
      <div class="container represent-grid">
        <div class="represent-copy reveal">
          <div>
            <p class="eyebrow">Quem Amauri representa</p>
            <h2 class="title">Famílias do interior que valorizam educação, trabalho, fé e tradição.</h2>
            <p class="lead">
              Mais oportunidades, trabalho e dignidade pra todos — sem que ninguém precise abandonar sua cidade pra
              crescer na vida.
            </p>
          </div>
          <div class="audience">
            {
              audienceGroups.map((item) => (
                <article>
                  <span class="audience-icon" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${audienceIcons[item.icon]}</svg>`} />
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- APOIE -->
    <section id="apoie" class="section section-dark">
      <div class="container support-grid">
        <div class="reveal">
          <p class="eyebrow on-dark">Rede de apoio</p>
          <h2 class="title">Some sua voz à nossa.</h2>
          <p class="lead">
            Entre na mobilização por uma voz forte pra São Francisco, o Norte de Minas, Esmeraldas, Caeté e Belo
            Horizonte.
          </p>
          <div class="support-contacts">
            <a href="tel:+5531998533595">(31) 99853-3595</a>
            <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">@dr_amauriwr</a>
          </div>
        </div>
        <div class="support-whatsapp reveal">
          <span>Contato direto</span>
          <h3>Fale com a campanha pelo WhatsApp.</h3>
          <p>Toque no botão para mandar uma mensagem e entrar na rede de apoio.</p>
          <a class="btn btn-milho" href={whatsappHref} target="_blank" rel="noreferrer">Ir para o WhatsApp</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <strong>Amauri Damião</strong>
        <p>Pré-candidato a Deputado Estadual · Democrata</p>
      </div>
      <div class="footer-mid">
        <img src="/assets/Logomarca_O_Democrata_35 - Alan Leal.png" alt="Democrata" width="1024" height="1024" />
      </div>
      <div class="footer-links">
        <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
        <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">Instagram</a>
        <span>São Francisco · Norte de Minas</span>
      </div>
    </div>
  </footer>

  <a class="whatsapp-float" href={whatsappHref} target="_blank" rel="noreferrer" aria-label="Falar pelo WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" />
    </svg>
    <strong>WhatsApp</strong>
  </a>

  <script>
    const header = document.querySelector('.site-header');
    const menuButton = document.querySelector('.menu-toggle');
    const mobileMenu = document.querySelector('.mobile-menu');

    const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);

    menuButton?.addEventListener('click', () => {
      const open = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!open));
      if (mobileMenu) (mobileMenu as HTMLElement).hidden = open;
    });

    mobileMenu?.querySelectorAll('a').forEach((link) =>
      link.addEventListener('click', () => {
        menuButton?.setAttribute('aria-expanded', 'false');
        (mobileMenu as HTMLElement).hidden = true;
      }),
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  </script>
</Layout>
