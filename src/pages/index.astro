---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const whatsappHref =
  'https://wa.me/5531998533595?text=Ol%C3%A1%2C%20quero%20apoiar%20a%20campanha%20do%20Amauri%20Dami%C3%A3o.';

const navItems = [
  { label: 'História', href: '#historia' },
  { label: 'Blog', href: '#blog' },
  { label: 'Propostas', href: '#bandeiras' },
  { label: 'Apoie', href: '#apoie' },
];

const dateFmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
const posts = (await getCollection('noticias', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const timeline = [
  {
    label: 'Origem',
    text: 'Natural do distrito de Jiboia, em São Francisco, cresceu perto da realidade das famílias rurais do Norte de Minas.',
  },
  {
    label: 'Formação',
    text: 'Ex-aluno das Escolas Caio Martins, em Esmeraldas. Atribui sua trajetória à disciplina, ao respeito e à educação que recebeu.',
  },
  {
    label: 'Compromisso',
    text: 'Não vem da política tradicional. Sua caminhada nasceu do trabalho e da convivência com as necessidades do povo.',
  },
];

const platform = [
  {
    title: 'Educação que transforma',
    text: 'Fortalecer a FUCAM, revitalizar as Escolas Caio Martins e ampliar o ensino técnico para os jovens do interior.',
  },
  {
    title: 'Emprego e renda',
    text: 'Atrair empresas, apoiar o comércio local, incentivar a agroindústria e qualificar a mão de obra da região. O maior programa social é o emprego.',
  },
  {
    title: 'Rio, turismo e cultura',
    text: 'Estruturar a rota turística do Rio São Francisco, valorizar a fé, a gastronomia, as praias fluviais e o Parque do Peruaçu.',
  },
  {
    title: 'Quem produz merece respeito',
    text: 'Defender a agricultura familiar com irrigação, estradas, energia, crédito rural e segurança hídrica.',
  },
];

const impactIcons: Record<string, string> = {
  educacao:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10 12 5 2 10l10 5 10-5Z"/><path d="M6 12v5c0 1.4 2.7 2.5 6 2.5s6-1.1 6-2.5v-5"/><path d="M22 10v5"/></svg>',
  compromissos:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="8" y="3" width="8" height="4" rx="1"/><path d="M9 5H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-3"/><path d="m9 14 2 2 4-4"/></svg>',
  trabalho:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><path d="M2 13h20"/></svg>',
};

const impactStats = [
  { icon: 'educacao', label: 'Educação como prioridade' },
  { icon: 'compromissos', label: 'Compromissos com a Caio Martins' },
  { icon: 'trabalho', label: 'Frentes de trabalho para o Norte de Minas' },
];

const regionalPlan = [
  'Água, irrigação e segurança hídrica para quem produz',
  'Estradas vicinais, acesso a mercados e apoio ao pequeno produtor',
  'Turismo de natureza, fé, gastronomia e cultura no Rio São Francisco',
];

---

<Layout>
  <header class="site-header">
    <div class="container header-inner">
      <a href="#inicio" class="brand" aria-label="Início — Amauri Damião">
        <img class="brand-candidate" src="/assets/logo-amauri.png" alt="Amauri Damião" width="1254" height="1254" />
        <span class="brand-sep" aria-hidden="true"></span>
        <picture>
          <source srcset="/assets/logo-democrata.webp" type="image/webp" />
          <img class="brand-democrata" src="/assets/logo-democrata.png" alt="Democrata 35" width="811" height="676" />
        </picture>
      </a>

      <nav class="nav" aria-label="Navegação principal">
        {navItems.map((item) => <a class="nav-link" href={item.href}>{item.label}</a>)}
      </nav>

      <div class="header-cta">
        <a class="btn btn-outline" href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">Instagram</a>
        <a class="btn btn-milho" href={whatsappHref} target="_blank" rel="noreferrer">Quero apoiar</a>
      </div>

      <button class="menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div class="mobile-menu" hidden>
      <div class="container">
        {navItems.map((item) => <a class="mobile-link" href={item.href}>{item.label}</a>)}
        <a class="btn btn-milho" style="margin-top:14px" href={whatsappHref} target="_blank" rel="noreferrer">Quero apoiar</a>
      </div>
    </div>
  </header>

  <main id="inicio">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true">
        <picture>
          <source media="(min-width: 1100px)" srcset="/assets/hero-amauri-desktop-navy.png" />
          <source media="(min-width: 700px) and (orientation: landscape)" srcset="/assets/hero-amauri-tablet-navy.png" />
          <img src="/assets/hero-amauri-mobile-navy.png" alt="" width="941" height="1672" />
        </picture>
      </div>

      <div class="container hero-grid">
        <div class="hero-copy reveal">
          <span class="hero-tagline">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 3 1 8l11 5 9-4.1V15h2V8L12 3ZM5 13.2V17c0 1.7 3.1 3 7 3s7-1.3 7-3v-3.8l-7 3.2-7-3.2Z" />
            </svg>
            Educação hoje, <b>futuro amanhã.</b>
          </span>

          <div class="hero-head">
            <h1 class="hero-name">Amauri</h1>
            <p class="hero-surname">DAMIÃO</p>
            <p class="hero-role">Pré-candidato a Deputado Estadual</p>
          </div>

          <p class="hero-headline">Mais escolas, mais oportunidades, <em>um futuro melhor</em> para todos.</p>
          <p class="hero-sub">
            Educação que transforma vidas, cria trabalho e abre caminhos para quem vive no interior de Minas.
          </p>

          <div class="hero-actions">
            <a class="btn hero-primary" href={whatsappHref} target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" />
              </svg>
              Fale com o Amauri
            </a>
            <a class="hero-secondary" href="#bandeiras">Conheça as bandeiras <span aria-hidden="true">↓</span></a>
          </div>
        </div>

      </div>

      <div class="hero-rail" aria-label="Compromissos centrais">
        <div class="container">
          <span>Educação</span>
          <span>Emprego e renda</span>
          <span>Desenvolvimento regional</span>
        </div>
      </div>
    </section>

    <!-- HISTÓRIA -->
    <section id="historia" class="section">
      <div class="container story-grid">
        <figure class="photo-doc reveal" style="margin:0">
          <img
            src="/assets/ChatGPT Image 11 de jun. de 2026, 11_39_32 - Alan Leal.png"
            alt="Amauri Damião conversando com moradores da zona rural, embaixo de uma árvore"
            width="941"
            height="1672"
          />
          <figcaption>Norte de Minas · lado a lado com o povo da roça</figcaption>
        </figure>

        <div class="reveal">
          <p class="eyebrow">História de vida</p>
          <h2 class="title">Da Jiboia às Escolas Caio Martins: disciplina, trabalho e compromisso.</h2>
          <div class="timeline">
            {
              timeline.map((item) => (
                <article>
                  <span>{item.label}</span>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- MINAS QUE EDUCA -->
    <section class="section education-band">
      <div class="education-band-bg" aria-hidden="true">
        <img src="/assets/ia-turma-escola-mg.png" alt="" width="1680" height="960" />
      </div>
      <div class="container education-panel reveal">
        <p class="eyebrow on-dark">Minas que educa</p>
        <h2 class="title">A escola precisa abrir caminho para o trabalho, a cidadania e a permanência no interior.</h2>
        <p class="lead">
          A proposta é tratar educação como infraestrutura de futuro: salas bem cuidadas, ensino técnico, esporte,
          cultura e formação conectada com a vida real das famílias mineiras.
        </p>
        <div class="impact-strip" aria-label="Resumo das prioridades">
          {
            impactStats.map((item) => (
              <article>
                <span class="impact-ico" set:html={impactIcons[item.icon]} />
                <span>{item.label}</span>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CITAÇÃO -->
    <section class="section band-quote">
      <div class="container reveal">
        <blockquote>A educação transformou minha vida, e pode transformar a vida de milhares de jovens mineiros.</blockquote>
        <cite>Amauri Damião</cite>
      </div>
    </section>

    <!-- BLOG -->
    <section id="blog" class="section section-dark">
      <div class="container">
        <div class="section-head reveal blog-head">
          <div>
            <p class="eyebrow on-dark">Blog</p>
            <h2 class="title">Ideias, propostas e a caminhada pelo Norte de Minas.</h2>
          </div>
          <a class="btn btn-outline" href="/blog">Ver todos</a>
        </div>

        {
          posts.length === 0 ? (
            <p class="lead">Em breve, novos conteúdos por aqui.</p>
          ) : (
            <div class="blog-list reveal">
              {posts.map((post) => (
                <article class="blog-card">
                  {post.data.image && (
                    <a class="blog-card-media" href={`/blog/${post.id}`}>
                      <img src={post.data.image} alt={post.data.imageAlt ?? ''} loading="lazy" />
                    </a>
                  )}
                  <div class="blog-card-body">
                    <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
                    <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
                    <p>{post.data.description}</p>
                    <a class="blog-more" href={`/blog/${post.id}`}>Ler mais →</a>
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <!-- BANDEIRAS -->
    <section id="bandeiras" class="section">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Bandeiras principais</p>
          <h2 class="title">Quatro frentes pra fazer o Norte de Minas voltar a crescer.</h2>
        </div>
        <div class="regional-feature reveal">
          <img
            src="/assets/ia-rio-sao-francisco-norte-mg.png"
            alt="Rio São Francisco, agricultura irrigada e comunidades rurais do Norte de Minas"
            width="1680"
            height="960"
          />
          <div class="regional-copy">
            <p class="eyebrow">Desenvolvimento regional</p>
            <h3>O Rio São Francisco, o campo e as cidades pequenas precisam estar no centro das decisões.</h3>
            <ul>
              {regionalPlan.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          </div>
        <div class="platform">
          {
            platform.map((item, i) => (
              <article class="platform-item reveal">
                <div class="platform-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="platform-body">
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- APOIE -->
    <section id="apoie" class="section section-dark">
      <div class="container support-grid">
        <div class="reveal">
          <p class="eyebrow on-dark">Rede de apoio</p>
          <h2 class="title">Some sua voz à nossa.</h2>
          <p class="lead">
            Entre na mobilização por uma voz forte pra São Francisco, o Norte de Minas, Esmeraldas, Caeté e Belo
            Horizonte.
          </p>
          <div class="support-contacts">
            <a href="tel:+5531998533595">(31) 99853-3595</a>
            <a href="mailto:Amauriwr84@gmail.com">Amauriwr84@gmail.com</a>
            <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">@dr_amauriwr</a>
          </div>
        </div>
        <div class="support-cta reveal">
          <span class="wa-circle wa-circle-lg">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" />
            </svg>
          </span>
          <h3>Fale direto pelo WhatsApp</h3>
          <p>Mande sua mensagem e some sua voz à nossa mobilização. É rápido e direto.</p>
          <a class="btn btn-milho" data-whatsapp href={whatsappHref} target="_blank" rel="noreferrer" style="width:100%">Falar no WhatsApp</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <picture>
          <source srcset="/assets/logo-amauri.webp" type="image/webp" />
          <img src="/assets/logo-amauri.png" alt="Amauri Damião" width="64" height="64" />
        </picture>
        <div>
          <strong>Amauri Damião</strong>
          <p>Pré-candidato a Deputado Estadual · Democrata</p>
        </div>
      </div>
      <div class="footer-mid">
        <img src="/assets/Logomarca_O_Democrata_35 - Alan Leal.png" alt="Democrata" width="1024" height="1024" />
      </div>
      <div class="footer-links">
        <a href="/blog">Blog</a>
        <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
        <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">Instagram</a>
        <span>São Francisco · Norte de Minas</span>
      </div>
    </div>
  </footer>

  <a class="whatsapp-float" data-whatsapp href={whatsappHref} target="_blank" rel="noreferrer" aria-label="Falar pelo WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.8-1.2-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.8.8 1.9.1.1.1.3 0 .5-.3.5-.5.7-.7 1-.2.2-.4.5-.2.8.2.4.9 1.5 2 2.4 1.3 1.2 2.4 1.5 2.7 1.7.3.1.5.1.7-.1.2-.3.8-.9 1-1.2.2-.3.4-.2.7-.1.3.1 1.8.8 2.1 1 .3.1.5.2.6.3.1.2.1.7-.1 1.3Z" />
    </svg>
    <strong>WhatsApp</strong>
  </a>

  <script>
    const menuButton = document.querySelector('.menu-toggle');
    const mobileMenu = document.querySelector('.mobile-menu');

    menuButton?.addEventListener('click', () => {
      const open = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!open));
      if (mobileMenu) (mobileMenu as HTMLElement).hidden = open;
    });

    mobileMenu?.querySelectorAll('a').forEach((link) =>
      link.addEventListener('click', () => {
        menuButton?.setAttribute('aria-expanded', 'false');
        (mobileMenu as HTMLElement).hidden = true;
      }),
    );

    // WhatsApp: no celular abre o app direto (deep link); no desktop usa wa.me
    const waPhone = '5531998533595';
    const waText = encodeURIComponent('Olá, quero apoiar a campanha do Amauri Damião.');
    const isMobile = /Android|iPhone|iPad|iPod|Opera Mini|IEMobile|Mobile/i.test(navigator.userAgent);
    document.querySelectorAll<HTMLAnchorElement>('[data-whatsapp]').forEach((el) => {
      el.href = isMobile
        ? `whatsapp://send?phone=${waPhone}&text=${waText}`
        : `https://wa.me/${waPhone}?text=${waText}`;
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</Layout>
