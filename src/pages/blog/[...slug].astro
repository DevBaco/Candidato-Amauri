---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('noticias', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const whatsappHref =
  'https://wa.me/5531998533595?text=Ol%C3%A1%2C%20quero%20apoiar%20a%20campanha%20do%20Amauri%20Dami%C3%A3o.';

const dateFmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Layout title={`${post.data.title} | Amauri Damião`} description={post.data.description} image={post.data.image}>
  <header class="site-header is-scrolled">
    <div class="container header-inner">
      <a href="/" class="brand" aria-label="Início — Amauri Damião">
        <img class="brand-candidate" src="/assets/logo-amauri.png" alt="Amauri Damião" width="1254" height="1254" />
        <span class="brand-sep" aria-hidden="true"></span>
        <picture>
          <source srcset="/assets/logo-democrata.webp" type="image/webp" />
          <img class="brand-democrata" src="/assets/logo-democrata.png" alt="Democrata 35" width="811" height="676" />
        </picture>
      </a>
      <div class="header-cta">
        <a class="btn btn-outline" href="/blog">Blog</a>
        <a class="btn btn-milho" href={whatsappHref} target="_blank" rel="noreferrer">Quero apoiar</a>
      </div>
    </div>
  </header>

  <main class="blog-page">
    <article class="section post-section">
      <div class="container post">
        <a class="post-back" href="/blog" aria-label="Voltar para todas as postagens">
          <span aria-hidden="true">←</span>
          Todas as postagens
        </a>
        <p class="eyebrow">Blog</p>
        <h1 class="title">{post.data.title}</h1>
        <p class="post-meta">
          <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
          <span>·</span>
          <span>{post.data.author}</span>
        </p>
        {
          post.data.image && (
            <figure class="post-cover">
              <img src={post.data.image} alt={post.data.imageAlt ?? ''} />
            </figure>
          )
        }
        <div class="post-content">
          <Content />
        </div>
        <aside class="post-conversion">
          <p class="eyebrow">Memória caiomartiniana</p>
          <h2>Você também viveu essa história?</h2>
          <p>Compartilhe sua lembrança das Escolas Caio Martins e converse diretamente com o Amauri.</p>
          <div class="post-cta-actions">
            <a class="btn btn-whatsapp post-cta" href={whatsappHref} target="_blank" rel="noreferrer">Fale com o Amauri</a>
            <a class="btn btn-outline" href="/#historia">Conheça sua trajetória</a>
          </div>
        </aside>
      </div>
    </article>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <picture>
          <source srcset="/assets/logo-amauri.webp" type="image/webp" />
          <img src="/assets/logo-amauri.png" alt="Amauri Damião" width="64" height="64" />
        </picture>
        <div>
          <strong>Amauri Damião</strong>
          <p>Pré-candidato a Deputado Estadual · Democrata</p>
        </div>
      </div>
      <div class="footer-links">
        <a href="/">Início</a>
        <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
        <a href="https://www.instagram.com/dr_amauriwr" target="_blank" rel="noreferrer">Instagram</a>
        <span>São Francisco · Norte de Minas</span>
      </div>
    </div>
  </footer>

  <a class="whatsapp-float" data-whatsapp href={whatsappHref} target="_blank" rel="noreferrer" aria-label="Falar pelo WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.57-.085 1.758-.719 2.006-1.413.248-.694.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.981.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26C2.168 6.442 6.603 2.01 12.055 2.01c2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.9 6.988c-.002 5.45-4.437 9.884-9.888 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.478-8.413Z" />
    </svg>
    <strong>WhatsApp</strong>
  </a>

  <script>
    const phone = '5531998533595';
    const text = encodeURIComponent('Olá, quero apoiar a campanha do Amauri Damião.');
    const isMobile = /Android|iPhone|iPad|iPod|Opera Mini|IEMobile|Mobile/i.test(navigator.userAgent);
    document.querySelectorAll<HTMLAnchorElement>('[data-whatsapp]').forEach((el) => {
      el.href = isMobile
        ? `whatsapp://send?phone=${phone}&text=${text}`
        : `https://wa.me/${phone}?text=${text}`;
    });
  </script>
</Layout>
