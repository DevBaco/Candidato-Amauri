---
import BlogArchivePage from '../../../components/BlogArchivePage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const BLOG_PAGE_SIZE = 6;
  const allPosts = (await getCollection('noticias', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  const totalPages = Math.max(1, Math.ceil(allPosts.length / BLOG_PAGE_SIZE));

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * BLOG_PAGE_SIZE;

    return {
      params: { page: String(currentPage) },
      props: {
        posts: allPosts.slice(start, start + BLOG_PAGE_SIZE),
        currentPage,
        totalPages,
      },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BlogArchivePage posts={posts} currentPage={currentPage} totalPages={totalPages} />
